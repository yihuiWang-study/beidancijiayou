      "version": 4
    }
  },
  "yXz0OFulKDMtBIUQ51QCc5": {
    "role": "editor",
    "value": {
      "createdAt": 1778340551717,
      "createdBy": "144115381524278509",
      "enabled": true,
      "id": "yXz0OFulKDMtBIUQ51QCc5",
      "parentId": "E9N3w0zwgvCSR7Z6YU6pp5",
      "parentTable": "block",
      "props": {
        "title": [
          [
            "I learned it by watching a cooking video by a very popular food blogger. I watched the video at home, just a couple of days before the Spring Festival, and used my laptop to follow along step by step. The blogger made everything look simple and fun, which was really helpful for a beginner like me. I could pause the video, replay some parts, and slowly follow the instructions without feeling too much pressure.",
            [
              [
                "b"
              ]
            ]
          ]
        ]
      },
      "spaceId": "300000000$NjSNnIQtBabS",
